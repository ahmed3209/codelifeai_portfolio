# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# JWT — change this to a long random string in production!
JWT_SECRET=byteburst-change-me-in-production-2025

# ── Database ────────────────────────────────────────────────────────────────
# Leave both blank locally → falls back to a local SQLite file at server/db/byteburst.db.
# In production set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN to point at your Turso DB.
#
# Get these from: https://turso.tech → Database → Connection details
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Local AI (Ollama) ───────────────────────────────────────────────────────
# Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
# Start server:   ollama serve
# Pull a model:   ollama pull llama3.2
#
# Ollama is local-only and will not work on a remote host like Render.
# In production the chatbot gracefully degrades to a contact-us fallback.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Dev:        http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
CLIENT_URL=http://localhost:5173
